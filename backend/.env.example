APP_NAME=Otmech.AI API
APP_ENV=development

DATABASE_URL=postgresql+psycopg://postgres:password@host:5432/railway
SECRET_KEY=change-me-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://otmechai-web.vercel.app

GIGACHAT_CREDENTIALS=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_VERIFY_SSL_CERTS=true
GIGACHAT_CA_BUNDLE_FILE=
GIGACHAT_MODEL=GigaChat

DGIS_API_KEY=
DGIS_BASE_URL=https://catalog.api.2gis.com/3.0/items
DGIS_TIMEOUT_SECONDS=20

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_TIMEZONE=Europe/Moscow

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
EMAIL_FROM=